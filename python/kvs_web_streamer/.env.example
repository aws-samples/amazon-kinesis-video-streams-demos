# Required Configuration
KVS_CHANNEL_NAME=your-webrtc-channel-name
KVS_STREAM_NAME=your-kvs-stream-name
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Optional - delete if unused
AWS_SESSION_TOKEN=

# Optional - Video Settings
VIDEO_WIDTH=640
VIDEO_HEIGHT=480
VIDEO_FPS=30

# Optional - Streaming Settings
# Duration of each MKV cluster in milliseconds (1000-10000)
# Lower values = lower latency but higher overhead
CLUSTER_DURATION_MS=2000

# Automatically insert keyframes for better seeking
AUTO_INSERT_KEYFRAME=false

# Maximum queue size for buffering
QUEUE_SIZE=100

# Optional - Logging
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=WARNING
